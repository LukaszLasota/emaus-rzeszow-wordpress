<?xml version="1.0"?>
<ruleset name="Comparison of Religions">
	<description>WordPress coding standards for Comparison of Religions plugin.</description>

	<!-- Scan these files -->
	<file>index.php</file>
	<file>uninstall.php</file>
	<file>app/</file>
	<file>tools/</file>
	<file>phpstan-bootstrap.php</file>
	<file>src/blocks/comparison-accordion/render.php</file>

	<!-- Exclude directories and non-PHP files -->
	<exclude-pattern>vendor/</exclude-pattern>
	<exclude-pattern>node_modules/</exclude-pattern>
	<exclude-pattern>build/</exclude-pattern>
	<exclude-pattern>*.js</exclude-pattern>
	<exclude-pattern>*.css</exclude-pattern>

	<!-- Use WordPress-Extra standard -->
	<rule ref="WordPress-Extra">
		<!-- Allow short array syntax -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
		<!-- PSR-4 autoloading - not WordPress file naming -->
		<exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
	</rule>

	<!-- WordPress documentation standards -->
	<rule ref="WordPress-Docs"/>

	<!-- Allow camelCase in render.php - variables match block.json attributes -->
	<rule ref="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase">
		<exclude-pattern>src/blocks/*/render.php</exclude-pattern>
	</rule>

	<!-- Allow short ternary in render templates -->
	<rule ref="Universal.Operators.DisallowShortTernary.Found">
		<exclude-pattern>src/blocks/*/render.php</exclude-pattern>
	</rule>

	<!-- Check for PHP cross-version compatibility -->
	<config name="minimum_supported_wp_version" value="6.4"/>
	<config name="testVersion" value="8.0-"/>

	<!-- Text domain -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="comparison-of-religions"/>
			</property>
		</properties>
	</rule>

	<!-- Allow . in hook names -->
	<rule ref="WordPress.NamingConventions.ValidHookName">
		<properties>
			<property name="additionalWordDelimiters" value="."/>
		</properties>
	</rule>

	<!-- Tabs for indentation -->
	<arg name="tab-width" value="4"/>

	<!-- Show colors and progress -->
	<arg name="colors"/>
	<arg value="sp"/>
</ruleset>