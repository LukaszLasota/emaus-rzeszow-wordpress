{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "comparison-of-religions/comparison-accordion",
	"title": "Porownanie wyznan - Akordeon",
	"category": "widgets",
	"icon": "editor-table",
	"textdomain": "comparison-of-religions",
	"description": "Wyswietla akordeon z porownaniem wyznan na podstawie danych CPT.",
	"attributes": {
		"selectedCategories": {
			"type": "array",
			"default": []
		}
	},
	"supports": {
		"html": false,
		"align": true,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true
		},
		"customClassName": true,
		"anchor": true
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./frontend.js",
	"render": "file:./render.php"
}
