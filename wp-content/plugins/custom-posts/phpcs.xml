<?xml version="1.0"?>
<ruleset name="Custom Posts">
    <description>WordPress coding standards for Custom Posts plugin.</description>

    <!-- Scan these files -->
    <file>custom-posts.php</file>
    <file>phpstan-bootstrap.php</file>
    <file>src/</file>

    <!-- Exclude directories -->
    <exclude-pattern>vendor/</exclude-pattern>

    <!-- Use WordPress-Extra standard -->
    <rule ref="WordPress-Extra">
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    </rule>

    <rule ref="WordPress-Docs"/>

    <config name="minimum_supported_wp_version" value="6.4"/>
    <config name="testVersion" value="8.0-"/>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="custom-posts"/>
            </property>
        </properties>
    </rule>

    <rule ref="WordPress.NamingConventions.ValidHookName">
        <properties>
            <property name="additionalWordDelimiters" value="."/>
        </properties>
    </rule>

    <arg name="tab-width" value="4"/>
    <arg name="colors"/>
    <arg value="sp"/>
</ruleset>