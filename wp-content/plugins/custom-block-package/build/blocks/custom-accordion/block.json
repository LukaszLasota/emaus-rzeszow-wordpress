{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "custom-block-package/custom-accordion",
  "title": "Dedykowany blok akordeon",
  "category": "custom-blocks-from-scratch",
  "icon": "menu",
  "description": "Lista akordeonów, każdy element można rozwijać.",
  "supports": {
    "html": false,
    "color": {
      "background": true,
      "text": true,
      "link": true,
      "gradients": true
    },
    "typography": {
