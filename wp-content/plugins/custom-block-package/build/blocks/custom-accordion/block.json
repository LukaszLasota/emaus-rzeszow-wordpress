      "fontFamily": true,
      "fontWeight": true,
      "fontStyle": true,
      "textTransform": true,
      "letterSpacing": true,
      "lineHeight": true,
      "textDecoration": true
    },
    "spacing": {
      "margin": true,
      "padding": true,
